pageType: content
background:
  type: solid
  color: "$background"
elements:
  # ===== OUTER GOLD FRAME =====
  - elementId: outer-frame
    elementType: shape
    bounds: [20, 20, 1240, 680]
    shapeName: rect
    border:
      style: solid
      width: 1
      color: "#C9A84C4D"

  # ===== INNER GOLD FRAME =====
  - elementId: inner-frame
    elementType: shape
    bounds: [28, 28, 1224, 664]
    shapeName: rect
    border:
      style: solid
      width: 1
      color: "#C9A84C1A"

  # ===== TOP CORNER BRACKETS =====
  - elementId: corner-tl-h
    elementType: shape
    bounds: [20, 20, 30, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "#C9A84C99"}
  - elementId: corner-tl-v
    elementType: shape
    bounds: [20, 20, 0, 30]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "#C9A84C99"}
  - elementId: corner-tr-h
    elementType: shape
    bounds: [1230, 20, 30, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "#C9A84C99"}
  - elementId: corner-tr-v
    elementType: shape
    bounds: [1260, 20, 0, 30]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "#C9A84C99"}
  - elementId: corner-bl-h
    elementType: shape
    bounds: [20, 680, 30, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "#C9A84C99"}
  - elementId: corner-bl-v
    elementType: shape
    bounds: [20, 670, 0, 30]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "#C9A84C99"}
  - elementId: corner-br-h
    elementType: shape
    bounds: [1230, 680, 30, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "#C9A84C99"}
  - elementId: corner-br-v
    elementType: shape
    bounds: [1260, 670, 0, 30]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "#C9A84C99"}

  # ===== BRAND LABEL =====
  - elementId: brand-label
    elementType: text
    bounds: [340, 28, 600, 18]
    content:
      style: "$brandLabel"
      align: [center, middle]
      wrap: false
      text: |
        <p>VILLA LEONESSA · BAB ATLAS · MARRAKECH</p>

  # ===== ORNAMENT LINE =====
  - elementId: ornament-line
    elementType: shape
    bounds: [540, 50, 200, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "#C9A84C66"}

  # ===== PAGE TITLE =====
  - elementId: page-title
    elementType: text
    bounds: [340, 62, 600, 50]
    content:
      style: "$title"
      align: [center, middle]
      wrap: false
      text: |
        <p>The House Attire</p>

  # ===== ROW 1 IMAGES =====
  - elementId: img-chef
    elementType: image
    bounds: [50, 125, 380, 220]
    src: "/mnt/agents/upload/chef-assistant.png"
    fit: {mode: cover}
    border: {style: solid, width: 1, color: "#C9A84C33"}

  - elementId: img-garden
    elementType: image
    bounds: [450, 125, 380, 220]
    src: "/mnt/agents/upload/gardening.png"
    fit: {mode: cover}
    border: {style: solid, width: 1, color: "#C9A84C33"}

  - elementId: img-house
    elementType: image
    bounds: [850, 125, 380, 220]
    src: "/mnt/agents/upload/housekeeping.png"
    fit: {mode: cover}
    border: {style: solid, width: 1, color: "#C9A84C33"}

  # ===== ROW 1 LABELS =====
  - elementId: lbl-chef
    elementType: text
    bounds: [50, 353, 380, 22]
    content:
      style: "$roleLabel"
      align: [center, middle]
      wrap: false
      text: |
        <p>CULINARY ARTS</p>

  - elementId: lbl-garden
    elementType: text
    bounds: [450, 353, 380, 22]
    content:
      style: "$roleLabel"
      align: [center, middle]
      wrap: false
      text: |
        <p>GARDEN &amp; GROUNDS</p>

  - elementId: lbl-house
    elementType: text
    bounds: [850, 353, 380, 22]
    content:
      style: "$roleLabel"
      align: [center, middle]
      wrap: false
      text: |
        <p>HOUSEKEEPING</p>

  # ===== ROW 2 IMAGES =====
  - elementId: img-manager
    elementType: image
    bounds: [50, 400, 380, 220]
    src: "/mnt/agents/upload/manager.png"
    fit: {mode: cover}
    border: {style: solid, width: 1, color: "#C9A84C33"}

  - elementId: img-maint
    elementType: image
    bounds: [450, 400, 380, 220]
    src: "/mnt/agents/upload/mantaince.png"
    fit: {mode: cover}
    border: {style: solid, width: 1, color: "#C9A84C33"}

  - elementId: img-security
    elementType: image
    bounds: [850, 400, 380, 220]
    src: "/mnt/agents/upload/security.png"
    fit: {mode: cover}
    border: {style: solid, width: 1, color: "#C9A84C33"}

  # ===== ROW 2 LABELS =====
  - elementId: lbl-manager
    elementType: text
    bounds: [50, 628, 380, 22]
    content:
      style: "$roleLabel"
      align: [center, middle]
      wrap: false
      text: |
        <p>RESIDENCE MANAGER</p>

  - elementId: lbl-maint
    elementType: text
    bounds: [450, 628, 380, 22]
    content:
      style: "$roleLabel"
      align: [center, middle]
      wrap: false
      text: |
        <p>ENGINEERING</p>

  - elementId: lbl-security
    elementType: text
    bounds: [850, 628, 380, 22]
    content:
      style: "$roleLabel"
      align: [center, middle]
      wrap: false
      text: |
        <p>SECURITY</p>

  # ===== FOOTER ORNAMENT LINE =====
  - elementId: footer-line
    elementType: shape
    bounds: [440, 658, 400, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "#C9A84C4D"}

  # ===== FOOTER TAGLINE =====
  - elementId: footer-tagline
    elementType: text
    bounds: [240, 670, 800, 18]
    content:
      style: "$caption"
      align: [center, middle]
      wrap: false
      text: |
        <p><em>Eleven centuries of Italian nobility, resting now in the shadow of the Atlas.</em></p>
